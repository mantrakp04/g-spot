{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "strict": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "types": ["vite/client"],
    "rootDirs": ["."],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@g-spot/ui/*": ["../../packages/ui/src/*"]
    },
    "noEmit": true
  },
  "include": ["src"]
}
