{
  "name": "@g-spot/db",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./schema": {
      "default": "./src/schema/index.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "db:push": "drizzle-kit generate && bun run src/migrate.ts",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "bun run src/migrate.ts"
  },
  "dependencies": {
    "@g-spot/env": "workspace:*",
    "@g-spot/types": "workspace:*",
    "dotenv": "catalog:",
    "drizzle-orm": "^0.45.2",
    "nanoid": "^5.1.7",
    "sqlite-vec": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@g-spot/config": "workspace:*",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6"
  }
}
